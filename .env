# --- AIRFLOW SECURITY CONFIGURATION ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# --- SYSTEM & USER MAPPING ---
AIRFLOW_UID=1000

# --- METADATA STORAGE LAYER (POSTGRES) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# --- AIRFLOW CORE CONFIGURATION ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO

# --- AIRFLOW 3 INTERNAL NETWORKING & SDK (POPRAWIONE) ---
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://airflow-webserver:8080/execution/
# Tryb deweloperski bypassujący autoryzację w UI
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_ALL_ADMINS=True

# Ścieżki Pythona wewnątrz kontenerów
PYTHONPATH=/opt/airflow
# Współdzielony klucz JWT dla komunikacji Task SDK (Airflow 3)
AIRFLOW__API_AUTH__JWT_SECRET=super-tajny-64-znakowy-klucz-jwt-dla-airflow-3-task-sdk-z-podpisem-sha512

# Definicja użytkowników w formacie JSON
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS='{"admin": "admin"}'
ENTSOE_API_KEY=your_actual_key_here_from_entsoe